---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProfileHeader from '../components/linktree/ProfileHeader.astro';
import QuoteRotator from '../components/linktree/QuoteRotator.astro';
import LinkButton from '../components/linktree/LinkButton.astro';
import ShareBar from '../components/linktree/ShareBar.astro';
import Icon from '../components/Icon.astro';
import { links } from '../data/links';
import { site } from '../data/site';
import { withBase } from '../utils/url';

const featured = links.find((l) => l.featured);
const rows = links.filter((l) => !l.featured);
const featuredHref = featured
  ? featured.internal
    ? withBase(featured.href)
    : featured.href
  : '#';
---

<BaseLayout bodyClass="page-linktree">
  <main class="card">
    <div class="brand-bar" aria-hidden="true"></div>
    <div class="card-in">
      <ProfileHeader />
      <QuoteRotator />

      {
        featured && (
          <>
            <a
              class="cta"
              href={featuredHref}
              {...featured.internal ? {} : { target: '_blank', rel: 'noopener noreferrer' }}
            >
              <Icon name={featured.icon} size={20} />
              {featured.title}
            </a>
            <p class="online">
              <span class="online-dot" aria-hidden="true" />
              Gratis · biasanya dibalas &lt; 1 jam
            </p>
          </>
        )
      }

      <nav class="rows" aria-label={`Kanal resmi ${site.name}`}>
        {rows.map((link) => <LinkButton link={link} />)}
      </nav>

      <div class="share-wrap">
        <ShareBar />
      </div>

      <p class="foot">
        {site.copyright}<br />{site.disclaimer}
      </p>
    </div>
  </main>
</BaseLayout>

<style>
  .card {
    width: min(100%, 460px);
    border-radius: 32px;
    background: var(--paper);
    border: 1px solid rgba(71, 6, 6, 0.06);
    box-shadow: 0 34px 80px rgba(124, 16, 25, 0.14);
    overflow: hidden;
  }

  .card-in {
    padding: clamp(30px, 7vw, 42px) clamp(24px, 6vw, 36px) 30px;
  }

  .cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 11px;
    margin-top: 26px;
    padding: 16px;
    border-radius: var(--r-full);
    background: linear-gradient(135deg, var(--azure), var(--azure-deep));
    box-shadow: 0 16px 34px rgba(225, 29, 42, 0.3);
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.01em;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .cta:hover,
  .cta:focus-visible {
    transform: translateY(-2px);
    box-shadow: 0 22px 46px rgba(225, 29, 42, 0.4);
  }

  .online {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    margin: 10px 0 0;
    font-size: 0.76rem;
    color: var(--muted);
  }

  .online-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #22c55e;
    box-shadow: 0 0 0 3px rgba(34, 197, 94, 0.22);
  }

  .rows {
    margin-top: 24px;
  }

  .share-wrap {
    margin-top: 26px;
  }

  .foot {
    margin: 24px 0 0;
    text-align: center;
    font-size: 0.72rem;
    line-height: 1.6;
    color: var(--muted);
  }
</style>
