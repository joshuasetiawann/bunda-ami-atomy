---
import { site } from '../../data/site';
import { profile } from '../../data/profile';
import { withBase } from '../../utils/url';
import Icon from '../Icon.astro';

const avatarSrc = site.avatar ? withBase(site.avatar) : '';

// Stat kepercayaan singkat dari slot pencapaian 2 (keluarga), 1 (tahun), 4 (rating).
// Rating tampil sebagai angka+★ tanpa label; slot 3 (mitra) tidak tampil di kartu.
const { stats: allStats } = profile.pencapaian;
const trust = [
  allStats[1] && { value: allStats[1].value, label: allStats[1].label.toLowerCase() },
  allStats[0] && { value: allStats[0].value, label: allStats[0].label.toLowerCase() },
  allStats[3] && { value: allStats[3].value.replace('/5', '★'), label: '' },
].filter((s): s is { value: string; label: string } => Boolean(s));
---

<header class="profile">
  <div class="avatar-wrap">
    <div class="avatar">
      {
        avatarSrc ? (
          <img src={avatarSrc} alt={`Foto ${site.name}`} width="96" height="96" />
        ) : (
          <span class="initials font-display">{site.initials}</span>
        )
      }
    </div>
    {
      site.verified && (
        <span class="badge" title="Terverifikasi">
          <Icon name="check" size={12} />
        </span>
      )
    }
  </div>

  <h1 class="name font-display">{site.name}</h1>

  <div class="role">
    <span class="role-check"><Icon name="check" size={10} /></span>
    <span>{site.role}</span>
  </div>

  {
    trust.length > 0 && (
      <div class="trust">
        {trust.map((t, i) => (
          <>
            {i > 0 && <span class="dot" aria-hidden="true" />}
            <span>
              <strong>{t.value}</strong>
              {t.label ? ` ${t.label}` : ''}
            </span>
          </>
        ))}
      </div>
    )
  }
</header>

<style>
  .profile {
    display: grid;
    justify-items: center;
    text-align: center;
  }

  .avatar-wrap {
    position: relative;
    width: 96px;
    height: 96px;
  }

  .avatar {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    display: grid;
    place-items: center;
    overflow: hidden;
    background: linear-gradient(150deg, #fff, var(--mist-2));
    border: 1px solid rgba(225, 29, 42, 0.25);
    box-shadow: 0 12px 30px rgba(124, 16, 25, 0.12);
  }

  .avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .initials {
    font-size: 2.15rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--azure-deep);
  }

  .badge {
    position: absolute;
    right: 0;
    bottom: 2px;
    width: 28px;
    height: 28px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    color: #fff;
    background: linear-gradient(135deg, var(--azure), var(--azure-deep));
    border: 3px solid var(--paper);
    box-shadow: 0 4px 12px rgba(179, 15, 27, 0.3);
  }

  .badge :global(svg) {
    stroke-width: 2.6;
  }

  .name {
    margin: 22px 0 0;
    font-size: clamp(1.7rem, 6.5vw, 2rem);
    font-weight: 500;
    line-height: 1.14;
    letter-spacing: -0.01em;
    color: var(--ink);
    text-wrap: balance;
  }

  .role {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 12px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .role-check {
    width: 18px;
    height: 18px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    color: #fff;
    background: var(--azure);
  }

  .role-check :global(svg) {
    stroke-width: 2.8;
  }

  .trust {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin-top: 16px;
    font-size: 0.8rem;
    color: var(--ink-2);
  }

  .trust strong {
    font-weight: 700;
  }

  .dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--gold);
  }
</style>
