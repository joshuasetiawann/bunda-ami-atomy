---
import type { LinkItem } from '../../data/links';
import { withBase } from '../../utils/url';
import Icon from '../Icon.astro';

interface Props {
  link: LinkItem;
}

const { link } = Astro.props;
const href = link.internal ? withBase(link.href) : link.href;
const external = !link.internal;
---

<a
  class:list={['link', { featured: link.featured }]}
  href={href}
  style={`--accent:${link.accent}`}
  {...external ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
>
  <span class="chip"><Icon name={link.icon} size={22} /></span>
  <span class="text">
    <span class="title">{link.title}</span>
    <span class="desc">{link.desc}</span>
  </span>
  <span class="go"><Icon name="chevron-right" size={20} /></span>
</a>

<style>
  .link {
    position: relative;
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 15px 18px;
    min-height: 70px;
    border: 1px solid var(--line);
    border-radius: var(--r-md);
    background: var(--glass-strong);
    backdrop-filter: blur(10px);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
    transition: transform 0.28s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.28s ease, border-color 0.28s ease;
  }

  /* garis aksen tipis di kiri */
  .link::before {
    content: '';
    position: absolute;
    left: 0;
    top: 14px;
    bottom: 14px;
    width: 3px;
    border-radius: 0 4px 4px 0;
    background: var(--accent);
    opacity: 0;
    transition: opacity 0.28s ease;
  }

  /* kilau saat hover */
  .link::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      115deg,
      transparent 30%,
      rgba(255, 255, 255, 0.55) 50%,
      transparent 70%
    );
    transform: translateX(-120%);
    transition: transform 0.7s ease;
    pointer-events: none;
  }

  .link:hover,
  .link:focus-visible {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--accent) 45%, transparent);
    box-shadow: var(--shadow-md);
  }

  .link:hover::before,
  .link:focus-visible::before {
    opacity: 1;
  }

  .link:hover::after {
    transform: translateX(120%);
  }

  .chip {
    flex: 0 0 46px;
    width: 46px;
    height: 46px;
    display: grid;
    place-items: center;
    border-radius: 13px;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 13%, white);
  }

  .text {
    min-width: 0;
    display: grid;
    gap: 2px;
    text-align: left;
  }

  .title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--ink);
    letter-spacing: -0.01em;
  }

  .desc {
    font-size: 0.8rem;
    line-height: 1.35;
    color: var(--muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .go {
    margin-left: auto;
    color: var(--muted);
    transition: transform 0.28s ease, color 0.28s ease;
  }

  .link:hover .go {
    transform: translateX(3px);
    color: var(--accent);
  }

  /* Tombol unggulan */
  .featured {
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--accent) 9%, white),
      white 70%
    );
    border-color: color-mix(in srgb, var(--accent) 24%, transparent);
    box-shadow: 0 16px 38px color-mix(in srgb, var(--accent) 22%, transparent);
  }

  .featured::before {
    opacity: 1;
    width: 4px;
  }

  .featured .title {
    font-size: 1.05rem;
  }

  @media (max-width: 380px) {
    .desc {
      display: none;
    }
    .link {
      min-height: 62px;
    }
  }
</style>
