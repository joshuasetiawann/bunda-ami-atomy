---
import { links } from '../../data/links';
import { withBase } from '../../utils/url';
import Icon from '../Icon.astro';

const wa = links.find((l) => l.id === 'whatsapp');
const waHref = wa ? wa.href : '#';
// kanal sosial untuk baris ikon (selain whatsapp & link internal)
const socials = links.filter((l) => !l.internal && l.id !== 'whatsapp');
---

<section class="sec cta" id="kontak">
  <div class="container">
    <div class="cta-panel reveal">
      <div class="cta-glow" aria-hidden="true"></div>
      <p class="eyebrow cta-eyebrow">Mari terhubung</p>
      <h2 class="cta-title font-display">
        Siap memulai hidup yang lebih sehat &amp; berdaya?
      </h2>
      <p class="cta-sub">
        Konsultasi gratis dan tanpa kewajiban. Si Batu Kali Menjadi Berlian senang menemani langkah pertamamu.
      </p>

      <div class="cta-actions">
        <a class="btn btn-primary" href={waHref} target="_blank" rel="noopener noreferrer">
          <Icon name="whatsapp" size={18} /> Konsultasi via WhatsApp
        </a>
        <a class="btn btn-ghost" href={withBase('/')}>
          <Icon name="arrow-up" size={18} /> Lihat semua tautan
        </a>
      </div>

      <div class="cta-socials">
        {
          socials.map((s) => (
            <a
              class="cta-soc"
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={s.title}
              style={`--accent:${s.accent}`}
            >
              <Icon name={s.icon} size={20} />
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .cta-panel {
    position: relative;
    text-align: center;
    padding: clamp(44px, 7vw, 80px) clamp(24px, 5vw, 56px);
    border-radius: var(--r-xl);
    background: linear-gradient(160deg, #fff, var(--mist-2));
    border: 1px solid rgba(255, 255, 255, 0.9);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
  }

  .cta-glow {
    position: absolute;
    inset: auto 50% -60% auto;
    transform: translateX(50%);
    width: 80%;
    height: 130%;
    background: radial-gradient(circle, rgba(225, 29, 42, 0.2), transparent 62%);
    pointer-events: none;
  }

  .cta-eyebrow {
    position: relative;
    justify-content: center;
  }

  .cta-eyebrow::before {
    display: none;
  }

  .cta-title {
    position: relative;
    margin-top: 16px;
    font-size: clamp(1.8rem, 4.6vw, 2.9rem);
    font-weight: 600;
    line-height: 1.12;
    letter-spacing: -0.02em;
    color: var(--ink);
    max-width: 18ch;
    margin-inline: auto;
  }

  .cta-sub {
    position: relative;
    margin: 18px auto 0;
    max-width: 50ch;
    font-size: 1.04rem;
    line-height: 1.7;
    color: var(--muted);
  }

  .cta-actions {
    position: relative;
    margin-top: 32px;
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    justify-content: center;
  }

  .cta-socials {
    position: relative;
    margin-top: 30px;
    display: flex;
    gap: 12px;
    justify-content: center;
  }

  .cta-soc {
    width: 46px;
    height: 46px;
    display: grid;
    place-items: center;
    border-radius: 13px;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 12%, white);
    border: 1px solid var(--line);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .cta-soc:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }
</style>
