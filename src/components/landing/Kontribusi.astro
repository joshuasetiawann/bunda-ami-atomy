---
import { profile } from '../../data/profile';
import Icon from '../Icon.astro';

const { kontribusi } = profile;
const topColors = ['var(--azure)', 'var(--sky)', 'var(--gold)'];
---

<section class="sec contrib" id="kontribusi">
  <div class="container">
    <div class="sec-head reveal">
      <p class="eyebrow">{kontribusi.eyebrow}</p>
      <h2 class="sec-title">{kontribusi.title}</h2>
      <p class="contrib-intro font-display">{kontribusi.intro}</p>
    </div>

    <div class="contrib-grid">
      {
        kontribusi.items.map((item, i) => (
          <article
            class="contrib-card reveal"
            style={`--top:${topColors[i % topColors.length]};transition-delay:${i * 80}ms`}
          >
            <span class="contrib-icon">
              <Icon name={item.icon} size={26} />
            </span>
            <h3 class="contrib-title">{item.title}</h3>
            <p class="contrib-desc">{item.desc}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .contrib-intro {
    margin-top: 18px;
    font-style: italic;
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--ink-2);
    max-width: 50ch;
  }

  .contrib-grid {
    margin-top: clamp(32px, 5vw, 52px);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }

  .contrib-card {
    padding: 28px clamp(20px, 3vw, 32px) 30px;
    border-top: 2px solid var(--top);
  }

  .contrib-card + .contrib-card {
    border-left: 1px solid var(--line);
  }

  .contrib-icon {
    display: flex;
    color: var(--azure-deep);
  }

  .contrib-icon :global(svg) {
    stroke-width: 1.6;
  }

  .contrib-title {
    margin-top: 16px;
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--ink);
  }

  .contrib-desc {
    margin-top: 8px;
    font-size: 0.94rem;
    line-height: 1.6;
    color: var(--muted);
  }

  @media (max-width: 860px) {
    .contrib-grid {
      grid-template-columns: 1fr;
    }
    .contrib-card + .contrib-card {
      border-left: none;
    }
  }
</style>
