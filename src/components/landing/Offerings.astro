---
import { profile } from '../../data/profile';
import Icon from '../Icon.astro';

const { offerings } = profile;
---

<section class="sec offer" id="tawaran">
  <div class="container">
    <div class="sec-head reveal">
      <p class="eyebrow">{offerings.eyebrow}</p>
      <h2 class="sec-title">{offerings.title}</h2>
    </div>

    <div class="offer-grid">
      {
        offerings.items.map((item, i) => (
          <article class="offer-card reveal" style={`transition-delay:${i * 60}ms`}>
            <span class="offer-icon">
              <Icon name={item.icon} size={22} />
            </span>
            <h3 class="offer-title font-display">{item.title}</h3>
            <p class="offer-desc">{item.desc}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .offer {
    background: var(--mist);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .offer-grid {
    margin-top: clamp(32px, 5vw, 56px);
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(20px, 3vw, 28px);
  }

  .offer-card {
    padding: 30px 30px 32px;
    border-radius: 20px;
    background: var(--paper);
    border: 1px solid var(--line);
  }

  .offer-icon {
    display: grid;
    place-items: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    color: var(--azure-deep);
    background: linear-gradient(150deg, #fff, var(--mist-2));
    border: 1px solid rgba(225, 29, 42, 0.2);
  }

  .offer-title {
    margin-top: 20px;
    font-weight: 500;
    font-size: 1.3rem;
    letter-spacing: -0.01em;
    color: var(--ink);
  }

  .offer-desc {
    margin-top: 10px;
    font-size: 0.98rem;
    line-height: 1.65;
    color: var(--muted);
  }

  @media (max-width: 700px) {
    .offer-grid {
      grid-template-columns: 1fr;
    }
    .offer-card {
      padding: 26px 24px;
    }
  }
</style>
