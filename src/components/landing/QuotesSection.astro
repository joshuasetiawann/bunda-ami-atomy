---
import { quotes } from '../../data/quotes';
import Icon from '../Icon.astro';

const first = quotes[0] ?? { text: '', author: '' };
---

<section class="quotes">
  <div class="quotes-in">
    <figure class="big-quote reveal">
      <span class="bq-mark"><Icon name="quote" size={52} /></span>
      <blockquote class="bq-text font-display" id="bq-text">{first.text}</blockquote>
      <figcaption
        class="bq-author"
        id="bq-author"
        data-empty={first.author ? 'false' : 'true'}
      >
        {first.author}
      </figcaption>
    </figure>
  </div>
</section>

<script define:vars={{ quotes }}>
  const t = document.getElementById('bq-text');
  const a = document.getElementById('bq-author');
  if (t && quotes.length > 1) {
    let i = 0;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const fig = t.closest('.big-quote');
    setInterval(() => {
      if (document.hidden) return;
      i = (i + 1) % quotes.length;
      const apply = () => {
        t.textContent = quotes[i].text;
        a.textContent = quotes[i].author || '';
        a.dataset.empty = quotes[i].author ? 'false' : 'true';
      };
      if (reduce) return apply();
      fig.classList.add('fading');
      setTimeout(() => {
        apply();
        fig.classList.remove('fading');
      }, 450);
    }, 6500);
  }
</script>

<style>
  .quotes {
    padding: clamp(60px, 11vw, 120px) 0;
  }

  .quotes-in {
    width: min(100% - var(--gutter) * 2, var(--narrow));
    margin-inline: auto;
    text-align: center;
  }

  .big-quote {
    margin: 0;
  }

  .bq-mark {
    display: inline-grid;
    place-items: center;
    color: var(--gold);
    opacity: 0.85;
  }

  .bq-text,
  .bq-author {
    transition: opacity 0.45s ease, transform 0.45s ease;
  }

  .bq-text {
    margin: 16px 0 0;
    font-size: clamp(1.5rem, 4vw, 2.3rem);
    font-style: italic;
    font-weight: 500;
    line-height: 1.4;
    letter-spacing: -0.015em;
    color: var(--ink);
  }

  .bq-author {
    margin-top: 20px;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--azure-deep);
  }

  .bq-author[data-empty='true'] {
    display: none;
  }

  .bq-author::before {
    content: '— ';
  }

  .fading .bq-text,
  .fading .bq-author {
    opacity: 0;
    transform: translateY(8px);
  }
</style>
