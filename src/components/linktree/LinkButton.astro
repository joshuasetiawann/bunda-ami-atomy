---
import type { LinkItem } from '../../data/links';
import { withBase } from '../../utils/url';
import Icon from '../Icon.astro';

interface Props {
  link: LinkItem;
}

const { link } = Astro.props;
const href = link.internal ? withBase(link.href) : link.href;
const external = !link.internal;
---

<a
  class="row"
  href={href}
  style={`--accent:${link.accent}`}
  {...external ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
>
  <span class="row-icon"><Icon name={link.icon} size={20} /></span>
  <span class="row-text">
    <span class="row-title">{link.title}</span>
    <span class="row-desc">{link.desc}</span>
  </span>
  <span class="row-go"><Icon name="chevron-right" size={16} /></span>
</a>

<style>
  .row {
    display: flex;
    align-items: center;
    gap: 15px;
    padding: 15px 4px;
    border-bottom: 1px solid var(--line);
    transition: padding-left 0.25s ease;
  }

  .row:last-child {
    border-bottom: none;
  }

  .row:hover,
  .row:focus-visible {
    padding-left: 9px;
  }

  .row-icon {
    display: flex;
    color: var(--accent);
  }

  .row-icon :global(svg) {
    stroke-width: 1.6;
  }

  .row-text {
    flex: 1;
    min-width: 0;
  }

  .row-title {
    display: block;
    font-size: 0.98rem;
    font-weight: 700;
    color: var(--ink);
  }

  .row-desc {
    display: block;
    font-size: 0.76rem;
    color: var(--muted);
  }

  .row-go {
    display: flex;
    color: var(--muted);
  }

  .row-go :global(svg) {
    stroke-width: 1.6;
  }
</style>
