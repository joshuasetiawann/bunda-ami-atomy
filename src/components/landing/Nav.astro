---
import { site } from '../../data/site';
import { links } from '../../data/links';
import { withBase } from '../../utils/url';
import Icon from '../Icon.astro';

const wa = links.find((l) => l.id === 'whatsapp');
const waHref = wa ? wa.href : '#';
---

<header class="nav" id="nav">
  <div class="container nav-in">
    <a class="brand" href={withBase('/')}>
      <span class="brand-mark font-display">{site.initials}</span>
      <span class="brand-name font-display">{site.name}</span>
    </a>

    <nav class="nav-actions">
      <a class="nav-link" href={withBase('/')}>Semua Tautan</a>
      <a class="nav-cta" href={waHref} target="_blank" rel="noopener noreferrer">
        <Icon name="whatsapp" size={16} /> Konsultasi
      </a>
    </nav>
  </div>
</header>

<script>
  const nav = document.getElementById('nav');
  const onScroll = () => nav?.classList.toggle('scrolled', window.scrollY > 24);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    padding: 16px 0;
    transition: background 0.3s ease, box-shadow 0.3s ease, padding 0.3s ease;
  }

  .nav.scrolled {
    padding: 11px 0;
    background: rgba(255, 250, 247, 0.82);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    box-shadow: 0 1px 0 rgba(71, 6, 6, 0.08);
  }

  .nav-in {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 11px;
  }

  .brand-mark {
    width: 38px;
    height: 38px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--azure-deep);
    background: linear-gradient(150deg, #fff, var(--mist-2));
    border: 1px solid rgba(225, 29, 42, 0.25);
  }

  .brand-name {
    font-size: 1.12rem;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.005em;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .nav-link,
  .nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border-radius: var(--r-full);
    font-size: 0.86rem;
    transition: transform 0.25s ease, color 0.2s ease;
  }

  .nav-link {
    padding: 9px 15px;
    font-weight: 600;
    color: var(--ink-2);
  }

  .nav-link:hover {
    color: var(--azure-deep);
  }

  .nav-cta {
    padding: 10px 18px;
    font-weight: 700;
    color: #fff;
    background: linear-gradient(135deg, var(--azure), var(--azure-deep));
    box-shadow: 0 10px 26px rgba(225, 29, 42, 0.28);
  }

  .nav-cta:hover {
    transform: translateY(-2px);
  }

  @media (max-width: 540px) {
    .brand-name {
      display: none;
    }
  }
</style>
