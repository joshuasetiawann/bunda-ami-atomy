---
import { site } from '../../data/site';
import { withBase } from '../../utils/url';

const year = '2026';
const navItems = [
  { label: 'Tentang', href: '#tentang' },
  { label: 'Pencapaian', href: '#pencapaian' },
  { label: 'Cerita', href: '#cerita' },
  { label: 'Kontak', href: '#kontak' },
];
---

<footer class="footer">
  <div class="container footer-in">
    <div class="footer-brand">
      <a class="footer-name font-display" href={withBase('/')}>{site.name}</a>
      <p class="footer-role">{site.role}</p>
    </div>

    <nav class="footer-nav" aria-label="Navigasi bawah">
      {navItems.map((n) => <a href={n.href}>{n.label}</a>)}
      <a href={withBase('/')}>Linktree</a>
    </nav>
  </div>

  <div class="container footer-bottom">
    <p>{site.copyright}. Seluruh hak cipta dilindungi.</p>
    <p class="footer-disclaimer">{site.disclaimer}</p>
  </div>
</footer>

<style>
  .footer {
    margin-top: clamp(20px, 4vw, 40px);
    padding: clamp(40px, 6vw, 60px) 0 32px;
    border-top: 1px solid var(--line);
    background: linear-gradient(180deg, transparent, rgba(225, 241, 251, 0.5));
  }

  .footer-in {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .footer-name {
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--ink);
  }

  .footer-role {
    margin-top: 4px;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--azure-deep);
  }

  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 22px;
  }

  .footer-nav a {
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--muted);
    transition: color 0.25s ease;
  }

  .footer-nav a:hover {
    color: var(--azure-deep);
  }

  .footer-bottom {
    margin-top: 28px;
    padding-top: 24px;
    border-top: 1px solid var(--line);
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 8px;
    font-size: 0.8rem;
    color: var(--muted);
  }

  .footer-disclaimer {
    max-width: 52ch;
  }

  @media (max-width: 620px) {
    .footer-bottom {
      flex-direction: column;
    }
  }
</style>
