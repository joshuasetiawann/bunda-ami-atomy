---
import { links } from '../../data/links';
import { withBase } from '../../utils/url';
import Icon from '../Icon.astro';

const wa = links.find((l) => l.id === 'whatsapp');
const waHref = wa ? wa.href : '#';
// kanal sosial untuk baris ikon (selain whatsapp, link internal & akun cadangan)
const socials = links.filter(
  (l) => !l.internal && l.id !== 'whatsapp' && l.id !== 'tiktok-2'
);
---

<section class="cta" id="kontak">
  <div class="container">
    <div class="cta-panel reveal">
      <div class="brand-bar cta-bar" aria-hidden="true"></div>
      <p class="cta-eyebrow">Mari Terhubung</p>
      <h2 class="cta-title font-display">
        Siap memulai hidup yang lebih sehat &amp; berdaya?
      </h2>
      <p class="cta-sub">
        Konsultasi gratis dan tanpa kewajiban. Si Batu Kali Menjadi Berlian senang
        menemani langkah pertamamu.
      </p>

      <div class="cta-actions">
        <a class="btn btn-primary" href={waHref} target="_blank" rel="noopener noreferrer">
          <Icon name="whatsapp" size={18} /> Konsultasi via WhatsApp
        </a>
        <a class="btn btn-ghost" href={withBase('/')}>
          <Icon name="arrow-up" size={18} /> Lihat semua tautan
        </a>
      </div>

      <div class="cta-socials">
        {
          socials.map((s) => (
            <a
              class="cta-soc"
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={s.title}
              style={`--accent:${s.accent}`}
            >
              <Icon name={s.icon} size={20} />
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .cta {
    padding: 0 0 clamp(60px, 10vw, 110px);
  }

  .cta-panel {
    position: relative;
    text-align: center;
    padding: clamp(48px, 8vw, 88px) clamp(24px, 5vw, 56px);
    border-radius: 32px;
    background: linear-gradient(160deg, #fff, var(--mist-2));
    border: 1px solid rgba(225, 29, 42, 0.14);
    overflow: hidden;
  }

  .cta-bar {
    position: absolute;
    inset: 0 0 auto 0;
  }

  .cta-eyebrow {
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--azure-deep);
  }

  .cta-title {
    margin: 16px auto 0;
    font-size: clamp(1.8rem, 4.6vw, 2.8rem);
    font-weight: 500;
    line-height: 1.12;
    letter-spacing: -0.02em;
    color: var(--ink);
    max-width: 18ch;
    text-wrap: balance;
  }

  .cta-sub {
    margin: 18px auto 0;
    max-width: 48ch;
    font-size: 1.04rem;
    line-height: 1.7;
    color: var(--muted);
  }

  .cta-actions {
    margin-top: 30px;
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    justify-content: center;
  }

  .cta-socials {
    margin-top: 28px;
    display: flex;
    gap: 10px;
    justify-content: center;
  }

  .cta-soc {
    width: 44px;
    height: 44px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    color: var(--accent);
    background: #fff;
    border: 1px solid var(--line);
    transition: transform 0.25s ease;
  }

  .cta-soc:hover {
    transform: translateY(-3px);
  }
</style>
