---
import { quotes } from '../../data/quotes';

const first = quotes[0] ?? { text: '', author: '' };
---

<figure class="quote">
  <blockquote class="q-text font-display" id="q-text">“{first.text}”</blockquote>
  <figcaption class="q-author" id="q-author" data-empty={first.author ? 'false' : 'true'}>
    {first.author}
  </figcaption>
</figure>

<script define:vars={{ quotes }}>
  const elText = document.getElementById('q-text');
  const elAuthor = document.getElementById('q-author');
  if (elText && quotes.length > 1) {
    let i = 0;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const fig = elText.closest('.quote');

    const show = (n) => {
      const q = quotes[n];
      elText.textContent = `“${q.text}”`;
      elAuthor.textContent = q.author || '';
      elAuthor.dataset.empty = q.author ? 'false' : 'true';
    };

    setInterval(() => {
      if (document.hidden) return;
      i = (i + 1) % quotes.length;
      if (reduce) {
        show(i);
        return;
      }
      fig.classList.add('fading');
      setTimeout(() => {
        show(i);
        fig.classList.remove('fading');
      }, 450);
    }, 6000);
  }
</script>

<style>
  .quote {
    margin: 20px auto 0;
    max-width: 34ch;
    text-align: center;
  }

  .q-text,
  .q-author {
    transition: opacity 0.45s ease, transform 0.45s ease;
  }

  .q-text {
    font-style: italic;
    font-size: 1.04rem;
    font-weight: 400;
    line-height: 1.5;
    color: var(--ink-2);
  }

  .q-author {
    margin-top: 9px;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--azure-deep);
  }

  .q-author[data-empty='true'] {
    display: none;
  }

  .q-author::before {
    content: '— ';
  }

  .fading .q-text,
  .fading .q-author {
    opacity: 0;
    transform: translateY(6px);
  }
</style>
