---
import { profile } from '../../data/profile';

const { cerita } = profile;
---

<section class="sec story" id="cerita">
  <div class="story-in">
    <div class="sec-head center reveal">
      <p class="eyebrow">{cerita.eyebrow}</p>
      <h2 class="sec-title">{cerita.title}</h2>
    </div>

    <ol class="timeline">
      {
        cerita.milestones.map((m, i) => (
          <li
            class:list={['tl-item', 'reveal', { last: i === cerita.milestones.length - 1 }]}
            style={`transition-delay:${i * 80}ms`}
          >
            <span class="tl-dot" aria-hidden="true" />
            <span class="tl-marker">{m.marker}</span>
            <h3 class="tl-title font-display">{m.title}</h3>
            <p class="tl-desc">{m.desc}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .story {
    background: var(--mist);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .story-in {
    width: min(100% - var(--gutter) * 2, var(--narrow));
    margin-inline: auto;
  }

  .sec-head.center {
    text-align: center;
    margin-inline: auto;
  }

  .timeline {
    list-style: none;
    margin: clamp(36px, 6vw, 56px) auto 0;
    padding-left: 32px;
    position: relative;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 8px;
    bottom: 8px;
    width: 1.5px;
    background: linear-gradient(180deg, var(--azure), var(--sky), var(--gold-soft));
  }

  .tl-item {
    position: relative;
    padding: 0 0 34px 8px;
  }

  .tl-item.last {
    padding-bottom: 0;
  }

  .tl-dot {
    position: absolute;
    left: -32px;
    top: 3px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--paper);
    border: 3px solid var(--azure);
  }

  .tl-item.last .tl-dot {
    background: var(--azure);
    border-color: var(--gold-soft);
  }

  .tl-marker {
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: #b5561a;
  }

  .tl-title {
    margin-top: 8px;
    font-size: 1.3rem;
    font-weight: 500;
    color: var(--ink);
  }

  .tl-desc {
    margin-top: 6px;
    font-size: 0.98rem;
    line-height: 1.65;
    color: var(--muted);
  }
</style>
