---
import { profile } from '../../data/profile';

const { cerita } = profile;
---

<section class="sec story" id="cerita">
  <div class="story-in">
    <div class="sec-head center reveal">
      <p class="eyebrow">{cerita.eyebrow}</p>
      <h2 class="sec-title">{cerita.title}</h2>
    </div>

    <ol class="timeline">
      {
        cerita.milestones.map((m, i) => (
          <li
            class:list={['tl-item', 'reveal', { last: i === cerita.milestones.length - 1 }]}
            style={`transition-delay:${i * 80}ms`}
          >
            <span class="tl-dot" aria-hidden="true" />
            <span class="tl-marker">{m.marker}</span>
            <h3 class="tl-title font-display">{m.title}</h3>
            <p class="tl-desc">{m.desc}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .story {
    background: var(--mist);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    overflow: hidden;
  }

  .story-in {
    width: min(100% - var(--gutter) * 2, var(--narrow));
    margin-inline: auto;
  }

  .sec-head.center {
    text-align: center;
    margin-inline: auto;
  }

  .timeline {
    list-style: none;
    margin: clamp(36px, 6vw, 56px) auto 0;
    padding-left: 32px;
    position: relative;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 8px;
    bottom: 8px;
    width: 1.5px;
    background: rgba(71, 6, 6, 0.12);
  }

  /* Garis progress: memanjang mengikuti scroll via --tl-progress (ScrollMotion) */
  .timeline::after {
    content: '';
    position: absolute;
    left: 7px;
    top: 8px;
    bottom: 8px;
    width: 1.5px;
    background: linear-gradient(180deg, var(--azure), var(--sky), var(--gold-soft));
    transform-origin: top;
    transform: scaleY(var(--tl-progress, 0));
  }

  /* Tanpa JS / reduce motion: garis langsung penuh */
  :global(html:not(.js)) .timeline::after {
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .timeline::after {
      transform: none;
    }
  }

  .tl-item {
    position: relative;
    padding: 0 0 34px 8px;
  }

  .tl-item.last {
    padding-bottom: 0;
  }

  /* Default = menyala (juga jadi fallback tanpa JS) */
  .tl-dot {
    position: absolute;
    z-index: 1; /* di atas garis progress .timeline::after */
    left: -32px;
    top: 3px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--azure);
    border: 3px solid var(--azure);
    box-shadow: 0 0 0 5px rgba(225, 29, 42, 0.12);
    transition: background 0.45s ease, box-shadow 0.45s ease,
      transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .tl-item.last .tl-dot {
    border-color: var(--gold-soft);
  }

  /* Padam sebelum item ter-reveal (hanya saat JS aktif) */
  :global(.js) .tl-item:not(.is-visible) .tl-dot {
    background: var(--paper);
    box-shadow: none;
    transform: scale(0.6);
  }

  .tl-marker {
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: #b5561a;
  }

  .tl-title {
    margin-top: 8px;
    font-size: 1.3rem;
    font-weight: 500;
    color: var(--ink);
  }

  .tl-desc {
    margin-top: 6px;
    font-size: 0.98rem;
    line-height: 1.65;
    color: var(--muted);
  }

  /* Item masuk bergantian: ganjil dari kiri, genap dari kanan.
     Menimpa transform .reveal global; stagger transition-delay inline tetap. */
  :global(.js) .tl-item.reveal {
    transform: translate3d(-30px, 14px, 0);
  }

  :global(.js) .tl-item.reveal:nth-child(even) {
    transform: translate3d(30px, 14px, 0);
  }

  /* WAJIB paling akhir: menang atas kedua rule di atas saat sudah tampil */
  :global(.js) .tl-item.reveal.is-visible {
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.js) .tl-item.reveal {
      opacity: 1;
      transform: none;
    }
  }
</style>
