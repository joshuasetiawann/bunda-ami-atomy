---
import { profile } from '../../data/profile';

const { cerita } = profile;
---

<section class="sec story" id="cerita">
  <div class="container">
    <div class="sec-head center reveal">
      <p class="eyebrow">{cerita.eyebrow}</p>
      <h2 class="sec-title">{cerita.title}</h2>
    </div>

    <ol class="timeline">
      {
        cerita.milestones.map((m, i) => (
          <li class="tl-item reveal" style={`transition-delay:${i * 90}ms`}>
            <span class="tl-dot" aria-hidden="true"></span>
            <div class="tl-content">
              <span class="tl-marker">{m.marker}</span>
              <h3 class="tl-title font-display">{m.title}</h3>
              <p class="tl-desc">{m.desc}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .timeline {
    list-style: none;
    max-width: 760px;
    margin: clamp(36px, 6vw, 60px) auto 0;
    padding-left: 36px;
    position: relative;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 9px;
    top: 6px;
    bottom: 6px;
    width: 2px;
    background: linear-gradient(180deg, var(--azure), var(--sky), var(--gold-soft));
  }

  .tl-item {
    position: relative;
    padding-bottom: 38px;
  }

  .tl-item:last-child {
    padding-bottom: 0;
  }

  .tl-dot {
    position: absolute;
    left: -34px;
    top: 4px;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: #fff;
    border: 4px solid var(--azure);
    box-shadow: 0 0 0 4px rgba(0, 152, 216, 0.12);
  }

  .tl-content {
    padding: 22px 26px;
    border-radius: var(--r-md);
    background: var(--glass-strong);
    border: 1px solid var(--line);
    box-shadow: var(--shadow-sm);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .tl-item:hover .tl-content {
    transform: translateX(4px);
    box-shadow: var(--shadow-md);
  }

  .tl-marker {
    display: inline-block;
    font-size: 0.74rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #b6892f;
    padding: 4px 12px;
    border-radius: var(--r-full);
    background: color-mix(in srgb, var(--gold) 22%, white);
  }

  .tl-title {
    margin-top: 12px;
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--ink);
  }

  .tl-desc {
    margin-top: 8px;
    font-size: 0.98rem;
    line-height: 1.65;
    color: var(--muted);
  }
</style>
