---
import { site } from '../../data/site';
import { profile } from '../../data/profile';
import { links } from '../../data/links';
import { withBase } from '../../utils/url';
import Icon from '../Icon.astro';
import Orbs from './Orbs.astro';

const { hero } = profile;
const wa = links.find((l) => l.id === 'whatsapp');
const waHref = wa ? wa.href : '#';
const avatarSrc = site.avatar ? withBase(site.avatar) : '';

// Tiga stat utama di hero, dari slot pencapaian 1 (tahun), 2 (keluarga), 4 (rating).
// Slot 3 (mitra) tidak tampil di desain ini.
const { stats: allStats } = profile.pencapaian;
const stats = [allStats[0], allStats[1], allStats[3]]
  .filter((s): s is NonNullable<typeof s> => Boolean(s))
  .map((s) => ({ ...s, value: s.value.replace('/5', '★') }));
---

<section class="hero">
  <Orbs variant="hero" />
  <div class="hero-in" data-plx="0.06">
    <div class="avatar-wrap">
      <div class="avatar">
        {
          avatarSrc ? (
            <img src={avatarSrc} alt={`Foto ${site.name}`} width="112" height="112" />
          ) : (
            <span class="initials font-display">{site.initials}</span>
          )
        }
      </div>
      {
        site.verified && (
          <span class="badge" title="Terverifikasi">
            <Icon name="check" size={13} />
          </span>
        )
      }
    </div>

    <p class="hero-eyebrow">{hero.eyebrow}</p>
    <h1 class="hero-title font-display">{hero.title}</h1>
    <p class="hero-tagline font-display">{hero.tagline}</p>
    <p class="hero-intro">{hero.intro}</p>

    <div class="hero-cta">
      <a class="btn btn-primary" href={waHref} target="_blank" rel="noopener noreferrer">
        <Icon name="whatsapp" size={18} /> Konsultasi dengan Bunda
      </a>
      <a class="btn btn-ghost" href="#cerita">
        Lihat cerita <Icon name="arrow-right" size={18} />
      </a>
    </div>

    {
      stats.length > 0 && (
        <div class="hero-stats">
          {stats.map((s, i) => (
            <>
              {i > 0 && <span class="stat-divider" aria-hidden="true" />}
              <div class="stat">
                <div class="stat-value font-display">{s.value}</div>
                <div class="stat-label">{s.label}</div>
              </div>
            </>
          ))}
        </div>
      )
    }
  </div>
</section>

<div class="container hero-rule" aria-hidden="true"></div>

<style>
  .hero {
    position: relative;
    z-index: 0;
    padding: clamp(44px, 8vw, 96px) 0 clamp(52px, 9vw, 104px);
  }

  .hero-in {
    width: min(100% - var(--gutter) * 2, var(--narrow));
    margin-inline: auto;
    text-align: center;
    display: grid;
    justify-items: center;
  }

  .avatar-wrap {
    position: relative;
    width: 112px;
    height: 112px;
  }

  .avatar {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    display: grid;
    place-items: center;
    overflow: hidden;
    background: linear-gradient(150deg, #fff, var(--mist-2));
    border: 1px solid rgba(225, 29, 42, 0.25);
    box-shadow: 0 16px 40px rgba(124, 16, 25, 0.12);
  }

  .avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .initials {
    font-size: 2.6rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--azure-deep);
  }

  .badge {
    position: absolute;
    right: 2px;
    bottom: 4px;
    width: 30px;
    height: 30px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    color: #fff;
    background: linear-gradient(135deg, var(--azure), var(--azure-deep));
    border: 3px solid var(--paper);
  }

  .badge :global(svg) {
    stroke-width: 2.4;
  }

  .hero-eyebrow {
    margin: 22px 0 0;
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--azure-deep);
  }

  .hero-title {
    margin: 16px 0 0;
    font-weight: 500;
    font-size: clamp(2.4rem, 6.5vw, 4rem);
    line-height: 1.06;
    letter-spacing: -0.025em;
    color: var(--ink);
    text-wrap: balance;
  }

  .hero-tagline {
    margin: 22px 0 0;
    font-style: italic;
    font-size: clamp(1.15rem, 2.6vw, 1.5rem);
    line-height: 1.44;
    color: var(--ink-2);
    max-width: 26ch;
  }

  .hero-intro {
    margin: 20px 0 0;
    max-width: 56ch;
    font-size: 1.04rem;
    line-height: 1.75;
    color: var(--muted);
  }

  .hero-cta {
    margin: 34px 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    justify-content: center;
  }

  .hero-stats {
    margin: 48px 0 0;
    width: 100%;
    max-width: 520px;
    display: flex;
    align-items: stretch;
    justify-content: center;
  }

  .stat {
    flex: 1;
    text-align: center;
  }

  .stat-value {
    font-size: clamp(1.8rem, 5vw, 2.4rem);
    font-weight: 500;
    color: var(--ink);
    line-height: 1;
  }

  .stat-label {
    margin-top: 6px;
    font-size: 0.74rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .stat-divider {
    width: 1px;
    background: var(--line-strong);
    margin: 6px 0;
  }

  .hero-rule {
    max-width: var(--narrow);
    height: 1px;
    background: var(--line);
  }
</style>
