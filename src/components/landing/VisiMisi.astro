---
import { profile } from '../../data/profile';
import Icon from '../Icon.astro';

const { visiMisi } = profile;
---

<section class="vm">
  <div class="container">
    <div class="vm-grid reveal">
      <div class="vm-visi">
        <p class="vm-eyebrow"><Icon name="eye" size={15} /> {visiMisi.visiTitle}</p>
        <p class="vm-statement font-display">{visiMisi.visi}</p>
      </div>

      <div class="vm-misi">
        <p class="vm-eyebrow"><Icon name="target" size={15} /> {visiMisi.misiTitle}</p>
        <ol class="vm-list">
          {visiMisi.misi.map((m) => <li>{m}</li>)}
        </ol>
      </div>
    </div>
  </div>
</section>

<style>
  .vm {
    padding: clamp(20px, 3vw, 32px) 0 clamp(56px, 10vw, 110px);
  }

  .vm-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(32px, 6vw, 80px);
  }

  .vm-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--azure-deep);
    margin-bottom: 16px;
  }

  .vm-statement {
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-style: italic;
    font-weight: 500;
    line-height: 1.34;
    letter-spacing: -0.01em;
    color: var(--ink);
  }

  .vm-list {
    list-style: none;
    counter-reset: misi;
  }

  .vm-list li {
    counter-increment: misi;
    position: relative;
    padding: 15px 0 15px 46px;
    font-size: 1rem;
    line-height: 1.55;
    color: var(--text);
    border-bottom: 1px solid var(--line);
  }

  .vm-list li:last-child {
    padding-bottom: 0;
    border-bottom: none;
  }

  .vm-list li::before {
    content: counter(misi, decimal-leading-zero);
    position: absolute;
    left: 0;
    top: 15px;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 500;
    color: var(--azure-deep);
  }

  @media (max-width: 760px) {
    .vm-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
